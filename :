apache:
  enabled: true
  page:
    title: "Infra Training"
    message: "Apache est déployé par Ansible"
  show_host: true
  allowed_users: 
    - devops
    - auditor
  - name: Create files for allowed users
    ansible.builtin.file:
      path: "/tmp/{{ item }}"
      state: touch
    loop: "{{ apache.allowed_users }}"
